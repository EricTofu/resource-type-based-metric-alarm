project            = "billing"
env                = "dev"
aws_region         = "<PRIMARY_REGION>"
ops_bucket         = "<ORG>-tfstate"
ops_state_role_arn = "<OPS_STATE_ROLE_ARN>"

lambda_concurrency_threshold = 900

common_tags = {
  ManagedBy   = "terraform"
  Environment = "dev"
}

# Fill each list with resources for this project.
# Types the project does not use stay as [].

alb_resources = [
