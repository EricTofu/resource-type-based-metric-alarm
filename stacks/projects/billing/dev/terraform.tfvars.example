  #     # Valid ALB IDs: elb_5xx, target_5xx, unhealthy_host
  #     disabled_alarms = ["target_5xx"]
  #   }
  # }
]

apigateway_resources  = []
ec2_resources         = []
asg_resources         = []
lambda_resources      = []
rds_resources         = []
s3_resources          = []
elasticache_resources = []
opensearch_resources  = []
ses_resources         = []
cloudfront_resources  = []
